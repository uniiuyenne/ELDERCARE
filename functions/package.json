    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.3.1",
    "firebase-functions": "^5.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/node": "^20.14.10",
    "eslint": "^9.10.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.8.0"
  }
}
