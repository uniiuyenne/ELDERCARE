{
  "name": "eldercare-notification-daemon",
  "version": "1.0.0",
  "private": true,
  "description": "Local daemon to send FCM + write in-app inbox notifications without Cloud Functions.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart eldercare-daemon",
    "pm2:stop": "pm2 stop eldercare-daemon",
    "pm2:logs": "pm2 logs eldercare-daemon",
    "pm2:delete": "pm2 delete eldercare-daemon",
    "lint": "node -e \"console.log('No lint configured')\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "firebase-admin": "^12.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
